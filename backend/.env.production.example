NODE_ENV=production

PORT=5001
FRONTEND_URL=https://your-reviewx-frontend-domain.example
CORS_ORIGIN=https://your-reviewx-frontend-domain.example

# MongoDB
# For Alibaba Cloud MongoDB replica set, use the VPC/private connection string.
# Passwords in MongoDB URI must be URL-encoded, for example "$" -> "%24".
MONGO_URI=mongodb://reviewx_app:{URL_ENCODED_PASSWORD}@{HOST1}:3717,{HOST2}:3717/reviewx?authSource=admin&replicaSet={REPLICA_SET}
MONGO_ADMIN_URI=mongodb://reviewx_db_admin:{URL_ENCODED_ADMIN_PASSWORD}@{HOST1}:3717,{HOST2}:3717/reviewx?authSource=admin&replicaSet={REPLICA_SET}
MONGO_AUTO_INDEX=false
MONGO_SERVER_SELECTION_TIMEOUT_MS=5000

# Storage / OSS
# Production uses OSS. Do not commit real OSS_ACCESS_KEY_ID or OSS_ACCESS_KEY_SECRET.
# Do not use an Alibaba Cloud root account AccessKey. Use a least-privilege RAM user or a future RAM Role.
# OSS_INTERNAL_ENDPOINT is for same-region ECS backend access over Alibaba Cloud internal network.
# OSS_PUBLIC_ENDPOINT is for browser-accessible signed download/preview URLs.
# Bucket should be private read/write; backend will generate short-lived signed URLs in a later phase.
STORAGE_DRIVER=oss
OSS_REGION=oss-cn-shenzhen
OSS_BUCKET=reviewx-prod-materials
OSS_INTERNAL_ENDPOINT=oss-cn-shenzhen-internal.aliyuncs.com
OSS_PUBLIC_ENDPOINT=oss-cn-shenzhen.aliyuncs.com
OSS_ACCESS_KEY_ID={your-ram-access-key-id}
OSS_ACCESS_KEY_SECRET={your-ram-access-key-secret}
OSS_OBJECT_PREFIX=reviewx

SESSION_COOKIE_NAME=reviewx_session
SESSION_TTL_MS=86400000
MAX_ACTIVE_SESSIONS_PER_USER=5
SESSION_COOKIE_SECURE=true
SESSION_COOKIE_SAME_SITE=lax

LLM_PROVIDER=bailian
BAILIAN_API_KEY={BAILIAN_API_KEY}
BAILIAN_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
BAILIAN_MODEL=qwen3.6-plus
BAILIAN_TIMEOUT_MS=90000
BAILIAN_MAX_RETRIES=1

CONSENSUS_DRAFT_COOLDOWN_SECONDS=60
