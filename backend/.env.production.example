NODE_ENV=production

PORT=5001
FRONTEND_URL=https://your-domain.example.com
CORS_ORIGIN=https://your-domain.example.com

# MongoDB
# For Alibaba Cloud MongoDB replica set, use the VPC/private connection string.
# Passwords in MongoDB URI must be URL-encoded, for example "$" -> "%24".
MONGO_URI=mongodb://root:<URL_ENCODED_PASSWORD>@<HOST1>:3717,<HOST2>:3717/reviewx?authSource=admin&replicaSet=<REPLICA_SET>
MONGO_ADMIN_URI=mongodb://root:<URL_ENCODED_PASSWORD>@<HOST1>:3717,<HOST2>:3717/reviewx?authSource=admin&replicaSet=<REPLICA_SET>
MONGO_SERVER_SELECTION_TIMEOUT_MS=5000

AI_FEEDBACK_PROVIDER=bailian
BAILIAN_API_KEY=
BAILIAN_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
BAILIAN_MODEL=qwen3.6-plus
# BAILIAN_TIMEOUT_MS=90000
# BAILIAN_MAX_RETRIES=1
