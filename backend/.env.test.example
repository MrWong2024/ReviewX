NODE_ENV=test

PORT=5001
FRONTEND_URL=http://localhost:3001
CORS_ORIGIN=http://localhost:3001

MONGO_URI=mongodb://reviewx_test_app:{REVIEWX_TEST_APP_PASSWORD}@127.0.0.1:27017/reviewx_test?authSource=reviewx_test
MONGO_ADMIN_URI=mongodb://reviewx_test_db_admin:{REVIEWX_TEST_DB_ADMIN_PASSWORD}@127.0.0.1:27017/reviewx_test?authSource=reviewx_test
MONGO_AUTO_INDEX=true
MONGO_SERVER_SELECTION_TIMEOUT_MS=5000

# Storage / OSS
# Automated tests must not depend on real Alibaba Cloud OSS.
# Later FakeStorageService or mock storage should be used for test automation.
# This task only records env examples; it does not implement FakeStorageService.
STORAGE_DRIVER=fake
OSS_REGION=oss-cn-shenzhen
OSS_BUCKET=reviewx-test-materials
OSS_INTERNAL_ENDPOINT=oss-cn-shenzhen-internal.aliyuncs.com
OSS_PUBLIC_ENDPOINT=oss-cn-shenzhen.aliyuncs.com
OSS_ACCESS_KEY_ID=test-placeholder
OSS_ACCESS_KEY_SECRET=test-placeholder
OSS_OBJECT_PREFIX=reviewx-test

SESSION_COOKIE_NAME=reviewx_session
SESSION_TTL_MS=86400000
MAX_ACTIVE_SESSIONS_PER_USER=5
SESSION_COOKIE_SECURE=false
SESSION_COOKIE_SAME_SITE=lax

LLM_PROVIDER=stub
BAILIAN_API_KEY=
BAILIAN_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
BAILIAN_MODEL=
BAILIAN_TIMEOUT_MS=90000
BAILIAN_MAX_RETRIES=1
