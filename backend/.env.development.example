NODE_ENV=development

PORT=5001
FRONTEND_URL=http://localhost:3001
CORS_ORIGIN=http://localhost:3001

MONGO_URI=mongodb://reviewx_dev_app:{REVIEWX_DEV_APP_PASSWORD}@127.0.0.1:27017/reviewx_dev?authSource=reviewx_dev
MONGO_ADMIN_URI=mongodb://reviewx_dev_db_admin:{REVIEWX_DEV_DB_ADMIN_PASSWORD}@127.0.0.1:27017/reviewx_dev?authSource=reviewx_dev
MONGO_AUTO_INDEX=true
MONGO_SERVER_SELECTION_TIMEOUT_MS=5000

LLM_PROVIDER=bailian
BAILIAN_API_KEY={BAILIAN_API_KEY}
BAILIAN_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
BAILIAN_MODEL=qwen3.6-plus
BAILIAN_TIMEOUT_MS=90000
BAILIAN_MAX_RETRIES=1
